# Telegram Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=
# Telegram - Optional user ID whitelist (comma-separated)
# Leave empty to allow all users
ALLOWED_TELEGRAM_USERS=

# Logging Configuration
LOG_LEVEL=INFO
LOG_OUTPUT=both
LOG_FILE_DIR=./logs
LOG_FILE_NAME=telecli
LOG_FILE_MODE=append
LOG_FILE_MAX_SIZE=100
LOG_DIR_MAX_SIZE=1000
LOG_ROTATION_INTERVAL=1d
LOG_WRITE_POSITION=bottom

# Terminal Configuration
TERMINAL_SHELL=bash
TERMINAL_TIMEOUT=300
TERMINAL_MAX_SESSIONS=100
TERMINAL_ENCODING=utf-8

# Web Server Configuration
WEB_HOST=127.0.0.1
WEB_PORT=8000
WEB_SSL_CERT=
WEB_SSL_KEY=

# Security Configuration
# Set AUTH_REQUIRED=true to require token for WebSocket connections
# Set ALLOWED_COMMANDS_ONLY=true to enforce command whitelist (requires ALLOWED_COMMANDS_FILE)
AUTH_REQUIRED=false
AUTH_TOKEN=
ALLOWED_COMMANDS_ONLY=false
ALLOWED_COMMANDS_FILE=./examples/allowed_commands.txt

# AI Proxy Configuration
AI_PROXY_ENABLED=false
AI_PROXY_PROVIDER=gemini-cli
# Options: gemini-cli, claude-cli, github-cli
AI_PROXY_SYSTEM_PROMPT=You are helping automate terminal interactions. Provide brief, direct responses.
AI_PROXY_MAX_ITERATIONS=10

# AI Proxy Buffer and Context Configuration
AI_PROXY_BUFFER_SIZE=1000
# Number of output lines to keep in memory (min: 100)
AI_PROXY_CONTEXT_LINES=500
# Number of lines to send to LLM for context (min: 50)
AI_PROXY_MAX_CONTEXT_SIZE=5000
# Maximum characters in context sent to LLM (min: 1000)

# LLM Provider Configuration
LLM_TIMEOUT_SECONDS=90
# Timeout for LLM provider responses in seconds (min: 10)
